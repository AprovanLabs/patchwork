{
  "extends": "@aprovan/tsconfig/base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noPropertyAccessFromIndexSignature": false
  },
  "exclude": ["node_modules", "dist", "**/dist", "**/node_modules"]
}
