{
  "name": "@aprovan/mcp-app-server",
  "version": "0.1.0",
  "description": "MCP App Server — hosts MCP tools that render interactive UIs in Claude Desktop and Claude web.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mcp-app-server": "./dist/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e:visual": "tsx src/e2e-visual.ts"
  },
  "dependencies": {
    "@aprovan/patchwork-compiler": "workspace:*",
    "@aprovan/patchwork-image-shadcn": "workspace:*",
    "@modelcontextprotocol/ext-apps": "^1.7.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.4.21",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "postcss": "^8.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.5",
    "vite-plugin-singlefile": "^2.3.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
