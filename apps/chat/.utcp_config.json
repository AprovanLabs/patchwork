{
  "manual_call_templates": [
    {
      "name": "weather",
      "call_template_type": "http",
      "url": "https://api.weather.gov/openapi.json",
      "http_method": "GET",
      "auth_tools": null,
      "headers": {
        "User-Agent": "com.aprovan.patchwork"
      }
    },
    {
      "name": "hardcopy",
      "call_template_type": "mcp",
      "config": {
        "mcpServers": {
          "hardcopy": {
            "transport": "stdio",
            "command": "npx",
            "args": [
              "@aprovan/hardcopy",
              "mcp-serve"
            ]
          }
        }
      }
    }
  ]
}